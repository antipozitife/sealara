### ------------------------------
### API (Node.js)
### ------------------------------
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
# Базовый URL этого API для браузера (без / в конце). Нужен, если SPA на другом домене — иначе аватары остаются относительными /uploads/...
PUBLIC_API_URL=
# Сколько reverse-proxy (nginx) перед Node — для корректных IP и cookie Secure. В проде за одним прокси: 1
TRUST_PROXY_HOPS=0
# Максимальный размер аватара после декодирования (байты). По умолчанию 15 МиБ (15728640)
AVATAR_MAX_BYTES=15728640
JWT_SECRET=change-me-in-production
ML_API_KEY=change-me-in-production
ML_SERVICE_URL=http://localhost:8001

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_WINDOW_MS=900000
REFRESH_RATE_LIMIT_MAX=30

RECENT_QUERIES_RETENTION_DAYS=90
RECENT_QUERIES_CLEANUP_INTERVAL_MS=21600000
DOCTOR_FEEDBACK_RETENTION_DAYS=365
AUTH_EVENTS_RETENTION_DAYS=365
ML_HEALTHCHECK_RETRIES=8
ML_HEALTHCHECK_DELAY_MS=1500
ML_RESPONSE_CACHE_TTL_MS=300000

REDIS_URL=redis://localhost:6379
REDIS_FEEDBACK_QUEUE_KEY=sealara:pending_feedback
REDIS_CONNECT_RETRIES=15
REDIS_CONNECT_DELAY_MS=1000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=Sealara

LOG_LEVEL=info
NODE_ENV=development
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_LIMIT=5
ML_PREDICT_USER_WINDOW_MS=60000
ML_PREDICT_USER_MAX=60
DOCTOR_CONFIRM_WINDOW_MS=3600000
DOCTOR_CONFIRM_MAX=30
ML_CIRCUIT_ERROR_THRESHOLD=50
ML_CIRCUIT_RESET_MS=30000
ML_CIRCUIT_VOLUME_THRESHOLD=5
SECURITY_ALERT_QUEUE_KEY=sealara:security:alerts
# Интеграция записи к врачу через Госуслуги (ЕПГУ/ESIA gateway)
GOSUSLUGI_MODE=mock
GOSUSLUGI_BASE_URL=
GOSUSLUGI_API_KEY=
GOSUSLUGI_TIMEOUT_MS=7000
GOSUSLUGI_GUID=SealaraGUID
# CSP: в dev можно включить report-only режим
CSP_REPORT_ONLY=0
# COEP policy: require-corp | credentialless
COEP_POLICY=credentialless
# Дополнительные origin для connect-src (через запятую)
CSP_CONNECT_SRC_EXTRA=
# Дополнительные источники для img-src (через запятую). PUBLIC_API_URL добавляется автоматически
CSP_IMG_SRC_EXTRA=
# Дополнительные источники для script-src (через запятую)
CSP_SCRIPT_SRC_EXTRA=
# Endpoint для CSP report-uri (опционально)
CSP_REPORT_URI=

### ------------------------------
### ML Service (FastAPI)
### ------------------------------
# Keep the same ML_API_KEY as API
# ML_API_KEY=change-me-in-production
DISEASES_JSON_PATH=./src/data/diseases.json

CONFIDENCE_THRESHOLD=0.7
RF_N_ESTIMATORS=300
CLARIFYING_SYMPTOMS_LIMIT=10
CONFIRMED_BATCH_SIZE=100
TORCH_EPOCHS=40
TORCH_MIN_CASES=100
TORCH_MIN_INTERVAL_SEC=300

# Optional persistence paths
MODELS_DIR=./models
MAX_STORED_MODEL_VERSIONS=5
REDIS_ACTIVE_VERSION_KEY=sealara:ml:active_model_version
MODEL_FILE_RF=./models/rf_model.joblib
MODEL_FILE_XGB=./models/xgb_model.joblib
MODEL_FILE_LGBM=./models/lgbm_model.joblib
MODEL_FILE_STACKED=./models/stacked_model.joblib
MODEL_FILE_TORCH=./models/torch_model.pt

REDIS_STATE_KEY=sealara:ml:state
# Сообщение другим репликам ML перезагрузить веса после switch / нового train
REDIS_MODEL_PUBSUB_CHANNEL=sealara:ml:model_events
# 0 — не поднимать фоновый Pub/Sub (удобно для изолированных pytest без Redis)
ML_MODEL_PUBSUB=1
# Rate limit на стороне ML (IP, скользящее окно)
ML_RATE_LIMIT_WINDOW_SEC=60
ML_RATE_LIMIT_MAX=120

# Set ENV=production in prod to enforce stricter checks
ENV=development
SYNTHETIC_AUGMENT=1
MAX_VOCAB_SIZE=1200
# Порог взаимной информации для отбора симптомов (feature selection)
MI_MIN_THRESHOLD=0.01
REDIS_READY_TIMEOUT_SEC=10
